# Backend API
PORT=3000
NODE_ENV=development

# Base de datos PostgreSQL (PostGIS)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=censo_indigena
DB_USER=censo
DB_PASSWORD=censo

# JWT (staff: censista/lider/analista/administrador)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# JWT (autogestión del habitante, Fase 14) — secretos SIEMPRE distintos de los de arriba,
# para que un token de un actor nunca sea válido para el otro.
JWT_HABITANTE_ACCESS_SECRET=change-me-habitante-access-secret
JWT_HABITANTE_ACCESS_EXPIRES_IN=15m
JWT_HABITANTE_REFRESH_EXPIRES_IN=7d
