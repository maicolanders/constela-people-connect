{
  "name": "web-educacion-feature",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/web/educacion/feature/src",
  "projectType": "library",
  "tags": ["scope:web", "type:feature", "domain:educacion"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/web/educacion/feature",
        "main": "libs/web/educacion/feature/src/index.ts",
        "tsConfig": "libs/web/educacion/feature/tsconfig.lib.json",
        "assets": ["libs/web/educacion/feature/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/web/educacion/feature/jest.config.cts"
      }
    }
  }
}
